# Dependencies
vendor/
node_modules/

# Build output
build/
dist/

# WordPress core and third-party
wp-content/uploads/
wp-content/upgrade/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment and secrets
.env
