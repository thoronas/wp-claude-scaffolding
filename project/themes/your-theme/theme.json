{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "768px",
            "wideSize": "1200px"
        },
        "color": {
            "palette": [
                {
                    "color": "#000000",
                    "name": "Black",
                    "slug": "black"
                },
                {
                    "color": "#ffffff",
                    "name": "White",
                    "slug": "white"
                }
            ]
        },
        "typography": {
            "fontFamilies": [],
            "fontSizes": []
        },
        "spacing": {
            "units": ["px", "em", "rem", "%", "vw", "vh"]
        }
    },
    "styles": {
        "spacing": {
            "blockGap": "1.5rem"
        }
    },
    "templateParts": [
        {
            "area": "header",
            "name": "header",
            "title": "Header"
        },
        {
            "area": "footer",
            "name": "footer",
            "title": "Footer"
        }
    ]
}
